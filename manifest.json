{
  "name": "ZeroRAM Suspender",
  "description": "__MSG_extDescription__",
  "author": "Yu-Hsiung Chiu, SELBER",
  "version": "0.1",
  "manifest_version": 3,
  "minimum_chrome_version": "88",
  "default_locale": "en",
  "permissions": [
    "tabs",
    "storage",
    "activeTab",
    "alarms",
    "favicon"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "ZeroRAM Suspender",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
"commands": {
    "01-toggle-suspend": {
      "suggested_key": {
        "default": "Ctrl+Shift+Z"
      },
      "description": "Aktivieren/Deaktivieren des aktiven Tabs"
    },
    "02-toggle-pause-suspend": {
      "description": "Automatische Suspension für den aktiven Tab pausieren/fortsetzen"
    },
    "03-suspend-selected": {
      "description": "Ausgewählte Tabs schlafen legen"
    },
    "04-unsuspend-selected": {
      "description": "Ausgewählte Tabs aufwecken"
    },
    "05-suspend-others-window": {
      "description": "Andere Tabs im aktiven Fenster schlafen legen"
    },
    "06-force-suspend-others-window": {
      "description": "Andere Tabs im aktiven Fenster erzwingen schlafen zu legen (z.B. trotz Audio/Formular)"
    },
    "07-suspend-all-all-windows": {
      "description": "Alle Tabs in allen Fenstern schlafen legen"
    },
    "08-force-suspend-all-all-windows": {
      "description": "Alle Tabs in allen Fenstern erzwingen schlafen zu legen"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["suspended.html", "suspended.js", "i18n.js", "style.css", "_favicon/*"],
      "matches": ["<all_urls>"],
      "extension_ids": ["*"]
    }
  ]
} 
